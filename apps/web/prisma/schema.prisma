generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  users         User[]
  clients       Client[]
  mediaFormats  MediaFormat[]
}

model User {
  id        String    @id @default(cuid())
  tenantId  String
  name      String?
  email     String    @unique
  password  String
  role      String    @default("ADMIN")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  accounts  Account[]
  sessions  Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Client {
  id        String     @id @default(cuid())
  tenantId  String
  name      String
  slug      String?
  contact   String?
  email     String?
  phone     String?
  address   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  campaigns Campaign[]
}

model Campaign {
  id         String          @id @default(cuid())
  name       String
  clientId   String
  status     String          @default("DRAFT")
  psdUrl     String?         @db.Text
  psdName    String?         @db.Text
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  client     Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assets     CampaignAsset[]
  keyVision  KeyVision?
  pieces     Piece[]
  deliveries Delivery[]
}

model CampaignAsset {
  id         String   @id @default(cuid())
  campaignId String
  type       String   @default("TEXT")
  label      String
  content    String?  @db.LongText
  value      String?  @db.Text
  imageUrl   String?  @db.LongText
  order      Int      @default(0)
  posX       Float    @default(100)
  posY       Float    @default(100)
  scaleX     Float    @default(1)
  scaleY     Float    @default(1)
  rotation   Float    @default(0)
  width      Int      @default(600)
  visible    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model KeyVision {
  id           String   @id @default(cuid())
  campaignId   String   @unique
  data         String?  @db.LongText
  bgColor      String   @default("#ffffff")
  layers       String?  @db.LongText
  width        Int      @default(1920)
  height       Int      @default(1080)
  thumbnailUrl String?  @db.LongText
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model Piece {
  id            String         @id @default(cuid())
  campaignId    String
  mediaFormatId String?
  name          String?
  status        String         @default("DRAFT")
  data          String?        @db.LongText
  imageUrl      String?        @db.LongText
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  campaign      Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  deliveries    DeliveryPiece[]
}

model Delivery {
  id         String          @id @default(cuid())
  campaignId String
  name       String?
  status     String          @default("PENDING")
  notes      String?         @db.Text
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  campaign   Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  files      DeliveryFile[]
  pieces     DeliveryPiece[]
}

model DeliveryFile {
  id         String   @id @default(cuid())
  deliveryId String
  name       String
  url        String   @db.Text
  size       Int?
  createdAt  DateTime @default(now())
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
}

model DeliveryPiece {
  id         String   @id @default(cuid())
  deliveryId String
  pieceId    String
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  piece      Piece    @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  @@unique([deliveryId, pieceId])
}

model MediaFormat {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  vehicle   String?
  media     String?
  format    String?
  width     Int
  height    Int
  dpi       Int?
  category  String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
}
