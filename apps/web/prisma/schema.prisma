// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── MULTITENANCY ───────────────────────────────────────────────
model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  clients       Client[]
  subscriptions Subscription[]
  mediaFormats  MediaFormat[]
}

// ─── USUÁRIOS ────────────────────────────────────────────────────
model User {
  id                   String   @id @default(cuid())
  name                 String?
  email                String   @unique
  password             String
  role                 Role     @default(USER)
  plan                 String   @default("FREE")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  blocked              Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  accounts Account[]
  sessions Session[]
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

// ─── NEXTAUTH ────────────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── PLANOS E ASSINATURAS ────────────────────────────────────────
model Plan {
  id            String   @id @default(cuid())
  name          String
  priceMonthly  Float
  priceYearly   Float
  stripePriceId String?
  maxUsers      Int
  maxCampaigns  Int
  features      Json
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  subscriptions Subscription[]
}

model Subscription {
  id                   String             @id @default(cuid())
  tenantId             String
  planId               String
  status               SubscriptionStatus @default(ACTIVE)
  stripeSubscriptionId String?
  stripeCustomerId     String?
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  plan   Plan   @relation(fields: [planId], references: [id])
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

// ─── CLIENTES DA AGÊNCIA ─────────────────────────────────────────
model Client {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  contact   String?
  email     String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  campaigns Campaign[]
}

// ─── CAMPANHAS ───────────────────────────────────────────────────
model Campaign {
  id        String   @id @default(cuid())
  name      String
  clientId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client     Client          @relation(fields: [clientId], references: [id])
  keyVision  KeyVision?
  pieces     Piece[]
  deliveries Delivery[]
  assets     CampaignAsset[]
}

// ─── ASSETS DA CAMPANHA ──────────────────────────────────────────
// content: JSON array de spans [ { text, styles: { fontSize, color, fontWeight, fontFamily } } ]
// imageUrl: URL da imagem (upload ou externa)
// position/scale/rotation: posicionamento no layout (layer)
model CampaignAsset {
  id         String    @id @default(cuid())
  campaignId String
  type       AssetType
  label      String
  // Conteúdo de texto (novo modelo semântico)
  content    Json?     // [ { text: string, styles: { fontSize, color, fontWeight, fontFamily } } ]
  // Compatibilidade com campo antigo
  value      String?   @db.Text
  imageUrl   String?   @db.Text
  order      Int       @default(0)
  // Posicionamento no layout (layer)
  posX       Float     @default(100)
  posY       Float     @default(100)
  scaleX     Float     @default(1)
  scaleY     Float     @default(1)
  rotation   Float     @default(0)
  width      Int       @default(600)
  visible    Boolean   @default(true)
  layerId    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

enum AssetType {
  TITULO
  SUBTITULO
  TEXTO
  TEXTO_APOIO
  CTA
  PERSONA
  PRODUTO
  FUNDO
  LOGOMARCA
  CUSTOM_TEXT
  CUSTOM_IMAGE
}

// ─── KEY VISION ──────────────────────────────────────────────────
// layers: JSON array [ { assetId, posX, posY, scaleX, scaleY, rotation, zIndex } ]
model KeyVision {
  id         String   @id @default(cuid())
  campaignId String   @unique
  data       Json     // legado Fabric — manter por ora
  layers     Json?    // novo modelo: [ { assetId, posX, posY, scaleX, scaleY, rotation, zIndex, width } ]
  bgColor    String   @default("#ffffff")
  width      Int      @default(1920)
  height     Int      @default(1080)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

// ─── PEÇAS ───────────────────────────────────────────────────────
model Piece {
  id         String      @id @default(cuid())
  campaignId String
  deliveryId String?
  name       String
  format     String
  width      Int
  height     Int
  dpi        Int         @default(72)
  data       Json
  status     PieceStatus @default(DRAFT)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  campaign Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  delivery Delivery? @relation(fields: [deliveryId], references: [id])
}

enum PieceStatus {
  DRAFT
  REVIEW
  APPROVED
  EXPORTED
}

// ─── ENTREGAS ────────────────────────────────────────────────────
model Delivery {
  id         String         @id @default(cuid())
  campaignId String
  number     Int
  totalSize  Int?
  status     DeliveryStatus @default(DRAFT)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  campaign Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  pieces   Piece[]
  files    DeliveryFile[]
}

enum DeliveryStatus {
  DRAFT
  REVIEW
  APPROVED
  SENT
}

// ─── ARQUIVOS DA ENTREGA ─────────────────────────────────────────
model DeliveryFile {
  id         String   @id @default(cuid())
  deliveryId String
  name       String
  extension  String
  url        String   @db.Text
  size       Int
  createdAt  DateTime @default(now())

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
}

// ─── FORMATOS DE MÍDIA ───────────────────────────────────────────
model MediaFormat {
  id        String        @id @default(cuid())
  tenantId  String?
  vehicle   String
  media     String
  format    String
  width     Int
  height    Int
  dpi       Int
  category  MediaCategory
  isDefault Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id])
}

enum MediaCategory {
  DIGITAL
  OFFLINE
}
