generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── TENANT ──────────────────────────────────────────────────────
model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  clients       Client[]
  campaigns     Campaign[]
  subscriptions Subscription[]
}

// ─── USUÁRIOS ────────────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  tenantId  String
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

// ─── CLIENTES ────────────────────────────────────────────────────
model Client {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  cnpj      String?
  email     String?
  phone     String?
  address   String?
  city      String?
  state     String?
  zip       String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  campaigns Campaign[]
}

// ─── CAMPANHAS ───────────────────────────────────────────────────
model Campaign {
  id        String   @id @default(cuid())
  tenantId  String
  clientId  String?
  name      String
  matrixData Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant          @relation(fields: [tenantId], references: [id])
  client  Client?         @relation(fields: [clientId], references: [id])
  fields  CampaignField[]
  medias  Media[]
}

// ─── FIELDS DA CAMPANHA ──────────────────────────────────────────
model CampaignField {
  id         String   @id @default(cuid())
  campaignId String
  label      String
  type       String   @default("titulo")
  value      String?  @db.Text
  imageUrl   String?
  order      Int      @default(0) @map("orders")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

// ─── MÍDIA ───────────────────────────────────────────────────────
model Media {
  id         String   @id @default(cuid())
  campaignId String
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  pieces   Piece[]
}

// ─── PEÇAS ───────────────────────────────────────────────────────
model Piece {
  id        String      @id @default(cuid())
  mediaId   String
  name      String
  format    String
  data      Json?
  status    PieceStatus @default(DRAFT)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  media      Media      @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  deliveries Delivery[]

  @@unique([mediaId, format])
}

enum PieceStatus {
  DRAFT
  REVIEW
  APPROVED
  EXPORTED
}

// ─── EXPORTAÇÕES ─────────────────────────────────────────────────
model Delivery {
  id        String   @id @default(cuid())
  pieceId   String
  url       String
  format    String
  createdAt DateTime @default(now())

  piece Piece @relation(fields: [pieceId], references: [id], onDelete: Cascade)
}

// ─── ASSINATURAS ─────────────────────────────────────────────────
model Subscription {
  id        String   @id @default(cuid())
  tenantId  String
  plan      String
  status    String
  stripeId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}
